@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --PrimaryBlue: #2563EB;
  --PrimaryYellow: #FACC15;
  --PrimaryRed: #DC2626;
  --SecondaryPurple: #7C3AED;
  --SecondaryTeal: #0D9488;
  --BackgroundDark: #0B1020;
  --SurfaceDark: #111827;
  --SurfaceLight: #1F2937;
  --TextPrimary: #F9FAFB;
  --TextSecondary: #9CA3AF;
  --Success: #16A34A;
  --Warning: #F59E0B;
  --Danger: #EF4444;
}

body {
  margin: 0;
  font-family: Inter, Arial, sans-serif;
  background: var(--BackgroundDark);
  color: var(--TextPrimary);
}

.LoginScreen {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 24px;
  background:
    radial-gradient(circle at 20% 20%, color-mix(in srgb, var(--SecondaryPurple) 28%, transparent), transparent 45%),
    radial-gradient(circle at 80% 80%, color-mix(in srgb, var(--PrimaryBlue) 26%, transparent), transparent 48%),
    var(--BackgroundDark);
}

.LoginShell {
  width: 100%;
  max-width: 580px;
  padding: 30px;
  border-radius: 22px;
  border: 1px solid color-mix(in srgb, var(--SecondaryPurple) 40%, var(--SurfaceLight));
  background:
    linear-gradient(160deg, color-mix(in srgb, var(--SurfaceDark) 95%, black), color-mix(in srgb, var(--SurfaceLight) 85%, black));
  box-shadow:
    0 24px 58px color-mix(in srgb, black 68%, transparent),
    inset 0 1px 0 color-mix(in srgb, white 9%, transparent);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.LoginHeader {
  display: grid;
  gap: 8px;
}

.LoginHeader h1 {
  margin: 0;
  font-size: 36px;
  line-height: 1.05;
  letter-spacing: 0.1px;
}

.LoginHeader p {
  margin: 0;
  color: var(--TextSecondary);
  font-size: 15px;
  max-width: 440px;
}

.LoginKicker {
  width: fit-content;
  border-radius: 999px;
  padding: 5px 10px;
  background: color-mix(in srgb, var(--PrimaryYellow) 22%, transparent);
  color: color-mix(in srgb, var(--PrimaryYellow) 84%, white);
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 35%, transparent);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.6px;
  text-transform: uppercase;
}

.LoginHighlights {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;
}

.LoginHighlights span {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 34%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 13%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 94%, var(--PrimaryBlue));
  font-size: 12px;
  padding: 7px 11px;
  font-weight: 600;
}

.LoginActionPanel {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 35%, transparent);
  background: linear-gradient(
    120deg,
    color-mix(in srgb, var(--SecondaryTeal) 13%, transparent),
    color-mix(in srgb, var(--SecondaryPurple) 9%, transparent)
  );
  padding: 13px;
  display: grid;
  gap: 3px;
}

.LoginActionPanel strong {
  font-size: 14px;
}

.LoginActionPanel small {
  color: var(--TextSecondary);
  font-size: 12px;
}

.LoginFootNote {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  color: color-mix(in srgb, var(--TextSecondary) 92%, white);
  font-size: 12px;
}

.LoginFootNote span {
  position: relative;
  padding-left: 14px;
}

.LoginFootNote span::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--PrimaryYellow) 78%, white);
  position: absolute;
  left: 0;
  top: 6px;
}

.DashboardRoot {
  padding: 24px;
  display: grid;
  gap: 16px;
}

.DashboardHero {
  display: grid;
  gap: 16px;
  border-radius: 18px;
  padding: 18px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 35%, var(--SurfaceLight));
  background:
    radial-gradient(circle at 85% 15%, color-mix(in srgb, var(--SecondaryPurple) 28%, transparent), transparent 48%),
    linear-gradient(145deg, color-mix(in srgb, var(--SurfaceDark) 95%, black), color-mix(in srgb, var(--SurfaceLight) 82%, black));
}

.DashboardHeroTitle {
  display: grid;
  gap: 8px;
}

.DashboardHeroTitle h1 {
  margin: 0;
  font-size: 30px;
  line-height: 1.05;
}

.DashboardHeroTitle p {
  margin: 0;
  color: var(--TextSecondary);
  max-width: 640px;
}

.DashboardHeroTag {
  width: fit-content;
  border-radius: 999px;
  padding: 5px 10px;
  font-size: 11px;
  font-weight: 700;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 42%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 20%, transparent);
  color: color-mix(in srgb, var(--PrimaryYellow) 88%, white);
}

.DashboardStatsGrid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
}

.DashboardStatCard {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 25%, var(--SurfaceLight));
  padding: 11px;
  display: flex;
  gap: 10px;
  align-items: center;
  background: color-mix(in srgb, var(--SurfaceDark) 85%, black);
}

.DashboardStatCard > div {
  flex: 1;
  min-width: 0;
}

.DashboardStatCard small {
  display: block;
  color: var(--TextSecondary);
  font-size: 12px;
}

.DashboardStatCard strong {
  font-size: 20px;
}

.DashboardXpMeta {
  margin-top: 2px;
}

.DashboardXpMeta small {
  color: color-mix(in srgb, var(--TextPrimary) 88%, var(--PrimaryBlue));
  font-size: 11px;
  font-weight: 600;
}

.DashboardXpBar {
  margin-top: 6px;
  width: 100%;
  height: 9px;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
}

.DashboardXpFill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--PrimaryBlue), var(--SecondaryPurple), var(--PrimaryYellow));
}

.DashboardIconTile {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  display: grid;
  place-items: center;
  font-size: 11px;
  font-weight: 700;
  color: white;
  background: linear-gradient(145deg, var(--SecondaryPurple), var(--PrimaryBlue));
}

.DashboardSection {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
  background: color-mix(in srgb, var(--SurfaceDark) 90%, black);
  padding: 16px;
  display: grid;
  gap: 12px;
}

.DashboardSectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 10px;
}

.DashboardSectionHeader h2 {
  margin: 0;
  font-size: 20px;
}

.DashboardSectionHeader small {
  color: var(--TextSecondary);
}

.DashboardNavGrid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.DashboardNavCard {
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 34%, transparent);
  background:
    radial-gradient(circle at 92% 12%, color-mix(in srgb, var(--SecondaryPurple) 16%, transparent), transparent 48%),
    color-mix(in srgb, var(--PrimaryBlue) 12%, transparent);
  padding: 12px;
  display: grid;
  gap: 8px;
  transition: transform 0.15s ease, border-color 0.15s ease;
}

.DashboardNavCard:hover {
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--PrimaryYellow) 48%, transparent);
}

.DashboardNavTopRow {
  display: grid;
  grid-template-columns: 32px minmax(0, 1fr) auto;
  align-items: center;
  gap: 8px;
}

.DashboardNavIcon {
  width: 32px;
  height: 32px;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 18%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 96%, var(--PrimaryBlue));
  display: grid;
  place-items: center;
  font-size: 11px;
  font-weight: 800;
}

.DashboardNavTopRow strong {
  font-size: 17px;
}

.DashboardNavCta {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 16%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryYellow));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.DashboardNavCard span {
  color: var(--TextSecondary);
  font-size: 13px;
  line-height: 1.3;
}

.DashboardEmptyState {
  border-radius: 10px;
  border: 1px dashed color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  padding: 16px;
  color: var(--TextSecondary);
}

.ChampionGrid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}

.ChampionCategoryStack {
  display: grid;
  gap: 12px;
}

.ChampionCategoryBlock {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 85%, transparent);
  background: color-mix(in srgb, black 12%, transparent);
  padding: 10px;
  display: grid;
  gap: 10px;
}

.ChampionCategoryHeader {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 10px;
}

.ChampionCategoryHeader small {
  color: var(--TextSecondary);
}

.ChampionCard {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 34%, transparent);
  background:
    radial-gradient(circle at 85% 10%, color-mix(in srgb, var(--PrimaryBlue) 16%, transparent), transparent 45%),
    color-mix(in srgb, var(--SecondaryTeal) 8%, var(--SurfaceDark));
  padding: 12px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.ChampionImageWrap {
  width: 84px;
  height: 84px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 90%, transparent);
  background: color-mix(in srgb, black 35%, transparent);
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.ChampionImage {
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
}

.ChampionImageFallback {
  color: var(--TextSecondary);
  font-weight: 700;
}

.ChampionMeta {
  display: grid;
  gap: 6px;
  width: 100%;
  min-width: 0;
}

.ChampionMeta strong {
  text-transform: capitalize;
  font-size: 18px;
}

.ChampionMeta small {
  color: var(--TextSecondary);
}

.ChampionTopRow {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}

.ChampionTopRow strong {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ChampionLevelBadge {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 16%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 94%, var(--PrimaryYellow));
  padding: 2px 7px;
  font-size: 10px;
  line-height: 1.1;
  font-weight: 700;
  flex-shrink: 0;
  white-space: nowrap;
}

.ChampionTagRow {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.ChampionTypeTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 45%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 15%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--SecondaryTeal));
  text-transform: capitalize;
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.ChampionMiniStat {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 42%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 13%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryBlue));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.ChampionRateRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.ChampionRateBar {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
}

.ChampionRateFill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--PrimaryBlue), var(--SecondaryTeal), var(--Success));
}

.ChampionFatigueRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.ChampionFatigueRow small {
  color: var(--TextSecondary);
}

.ChampionFatigueBar {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
}

.ChampionFatigueFill {
  height: 100%;
  border-radius: 999px;
}

.ChampionFatigueFillReady {
  background: linear-gradient(90deg, var(--SecondaryTeal), var(--Success));
}

.ChampionFatigueFillTired {
  background: linear-gradient(90deg, var(--Danger), var(--Warning));
}

.ChampionEvolutionStatus {
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--SecondaryPurple) 35%, transparent);
  background: color-mix(in srgb, var(--SecondaryPurple) 12%, transparent);
  padding: 6px 8px;
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--SecondaryPurple));
  font-size: 11px;
  font-weight: 700;
}

.PokemonRoot {
  padding: 24px;
  display: grid;
  gap: 16px;
}

.PageQuickNav {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.PageQuickNavLink {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 35%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 10%, transparent);
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 600;
}

.PokemonHero {
  border-radius: 18px;
  padding: 18px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 35%, var(--SurfaceLight));
  background:
    radial-gradient(circle at 90% 10%, color-mix(in srgb, var(--SecondaryTeal) 25%, transparent), transparent 44%),
    linear-gradient(150deg, color-mix(in srgb, var(--SurfaceDark) 95%, black), color-mix(in srgb, var(--SurfaceLight) 84%, black));
  display: grid;
  gap: 12px;
}

.PokemonHeroTop {
  display: grid;
  gap: 8px;
}

.PokemonHeroTag {
  width: fit-content;
  border-radius: 999px;
  padding: 5px 10px;
  font-size: 11px;
  font-weight: 700;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 42%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 19%, transparent);
  color: color-mix(in srgb, var(--PrimaryYellow) 88%, white);
}

.PokemonHeroTop h1 {
  margin: 0;
  font-size: 30px;
}

.PokemonHeroTop p {
  margin: 0;
  color: var(--TextSecondary);
  max-width: 760px;
}

.PokemonHeroPills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.PokemonHeroPills span {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 35%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 12%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--SecondaryTeal));
  font-size: 12px;
  font-weight: 600;
  padding: 6px 10px;
}

.PokemonSection {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
  background: color-mix(in srgb, var(--SurfaceDark) 90%, black);
  padding: 16px;
  display: grid;
  gap: 12px;
}

.PokemonSectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 10px;
}

.PokemonSectionHeader h2 {
  margin: 0;
  font-size: 20px;
}

.PokemonSectionHeader small {
  color: var(--TextSecondary);
}

.PokemonGrid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.PokemonCard {
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--SecondaryPurple) 36%, transparent);
  background:
    radial-gradient(circle at 88% 14%, color-mix(in srgb, var(--PrimaryBlue) 14%, transparent), transparent 42%),
    color-mix(in srgb, var(--SecondaryPurple) 10%, var(--SurfaceDark));
  padding: 12px;
  display: grid;
  gap: 12px;
  align-items: flex-start;
}

.PokemonCardImageWrap {
  width: 66px;
  height: 66px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 90%, transparent);
  background: color-mix(in srgb, black 35%, transparent);
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.PokemonCardImage {
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
}

.PokemonCardImageFallback {
  color: var(--TextSecondary);
  font-weight: 700;
}

.PokemonCardMeta {
  display: grid;
  gap: 6px;
  width: 100%;
}

.PokemonCardTopRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.PokemonCardMeta strong {
  text-transform: capitalize;
  font-size: 18px;
}

.PokemonCardLevelBadge {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 16%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryYellow));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
  white-space: nowrap;
}

.PokemonCardMeta small {
  color: var(--TextSecondary);
}

.PokemonMetaTopLine {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.PokemonCardTypeTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 45%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 14%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 96%, var(--SecondaryTeal));
  text-transform: capitalize;
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.PokemonCardMiniTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 13%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 96%, var(--PrimaryBlue));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.PokemonStatsGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(82px, 1fr));
  gap: 6px;
}

.PokemonStatsGrid span {
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  padding: 6px 8px;
  font-size: 11px;
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryBlue));
  font-weight: 600;
}

.PokemonProgressRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.PokemonProgressBar,
.PokemonWinBar {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
}

.PokemonProgressFill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--PrimaryBlue), var(--SecondaryPurple), var(--PrimaryYellow));
}

.PokemonWinFill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--SecondaryTeal), var(--Success));
}

.PokemonCooldowns {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.PokemonStatusTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 14%, var(--SurfaceDark));
  color: var(--TextSecondary);
  padding: 4px 8px;
  font-size: 11px;
  font-weight: 700;
}

.PokemonStatusReady {
  border-color: color-mix(in srgb, var(--Success) 48%, transparent);
  background: color-mix(in srgb, var(--Success) 14%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 92%, var(--Success));
}

.PokemonStatusWaiting {
  border-color: color-mix(in srgb, var(--Warning) 48%, transparent);
  background: color-mix(in srgb, var(--Warning) 14%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 92%, var(--Warning));
}

.PokemonEmptyState {
  border-radius: 12px;
  border: 1px dashed color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  padding: 14px;
  display: flex;
  gap: 12px;
  align-items: center;
  background: color-mix(in srgb, var(--PrimaryBlue) 8%, transparent);
}

.PokemonEmptyIcon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 20%, transparent);
  color: white;
  display: grid;
  place-items: center;
  font-size: 12px;
  font-weight: 800;
  flex-shrink: 0;
}

.PokemonEmptyContent {
  display: grid;
  gap: 4px;
}

.PokemonEmptyContent strong {
  font-size: 15px;
}

.PokemonEmptyContent p {
  margin: 0;
  color: var(--TextSecondary);
}

.StarterGrid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.StarterCard {
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 33%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 11%, var(--SurfaceDark));
  padding: 12px;
  display: grid;
  gap: 10px;
}

.StarterImageWrap {
  width: 100%;
  height: 120px;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 90%, transparent);
  background: color-mix(in srgb, black 35%, transparent);
  display: grid;
  place-items: center;
}

.StarterImage {
  width: 88px;
  height: 88px;
  object-fit: contain;
  image-rendering: pixelated;
}

.StarterImageFallback {
  color: var(--TextSecondary);
  font-weight: 700;
}

.StarterMeta {
  display: grid;
  gap: 3px;
}

.StarterMeta strong {
  text-transform: capitalize;
}

.StarterMeta small {
  color: var(--TextSecondary);
}

.StarterClaimButton {
  border: none;
  border-radius: 10px;
  padding: 10px 12px;
  background: linear-gradient(145deg, var(--PrimaryBlue), var(--SecondaryPurple));
  color: white;
  font-weight: 700;
  cursor: pointer;
}

.BattlesRoot {
  padding: 24px;
  display: grid;
  gap: 16px;
}

.BattlesHero {
  border-radius: 18px;
  padding: 18px;
  border: 1px solid color-mix(in srgb, var(--SecondaryPurple) 35%, var(--SurfaceLight));
  background:
    radial-gradient(circle at 90% 12%, color-mix(in srgb, var(--SecondaryPurple) 28%, transparent), transparent 45%),
    linear-gradient(150deg, color-mix(in srgb, var(--SurfaceDark) 95%, black), color-mix(in srgb, var(--SurfaceLight) 84%, black));
  display: grid;
  gap: 12px;
}

.BattlesHeroTop {
  display: grid;
  gap: 8px;
}

.BattlesHeroTag {
  width: fit-content;
  border-radius: 999px;
  padding: 5px 10px;
  font-size: 11px;
  font-weight: 700;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 42%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 19%, transparent);
  color: color-mix(in srgb, var(--PrimaryYellow) 88%, white);
}

.BattlesHeroTop h1 {
  margin: 0;
  font-size: 30px;
}

.BattlesHeroTop p {
  margin: 0;
  color: var(--TextSecondary);
  max-width: 760px;
}

.BattlesHeroPills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.BattlesHeroPills span {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SecondaryPurple) 35%, transparent);
  background: color-mix(in srgb, var(--SecondaryPurple) 12%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--SecondaryPurple));
  font-size: 12px;
  font-weight: 600;
  padding: 6px 10px;
}

.BattlesSection {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
  background: color-mix(in srgb, var(--SurfaceDark) 90%, black);
  padding: 16px;
  display: grid;
  gap: 12px;
}

.BattlesSectionHeader {
  display: grid;
  gap: 4px;
}

.BattlesSectionHeader h2 {
  margin: 0;
  font-size: 20px;
}

.BattlesSectionHeader small {
  color: var(--TextSecondary);
}

.BattleOngoingGrid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}

.BattleOngoingCard {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 32%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 10%, var(--SurfaceDark));
  padding: 12px;
  display: grid;
  gap: 5px;
}

.BattleOngoingTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.BattleOngoingStatus {
  border-radius: 999px;
  padding: 4px 8px;
  font-size: 11px;
  font-weight: 700;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  text-transform: uppercase;
}

.BattleOngoingStatusActive {
  border-color: color-mix(in srgb, var(--Success) 50%, transparent);
  background: color-mix(in srgb, var(--Success) 18%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 90%, var(--Success));
}

.BattleOngoingStatusPending {
  border-color: color-mix(in srgb, var(--Warning) 50%, transparent);
  background: color-mix(in srgb, var(--Warning) 18%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 90%, var(--Warning));
}

.BattleOngoingCard strong {
  text-transform: capitalize;
}

.BattleOngoingCard small {
  color: var(--TextSecondary);
}

.BattleFormGrid {
  display: grid;
  gap: 10px;
  max-width: 560px;
}

.BattleFormField {
  display: grid;
  gap: 6px;
}

.BattleFormField span {
  font-size: 12px;
  color: var(--TextSecondary);
  font-weight: 600;
}

.BattleFormField input {
  width: 100%;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, black 20%, var(--SurfaceDark));
  color: var(--TextPrimary);
  padding: 10px 12px;
  outline: none;
}

.BattleSelectInput {
  width: 100%;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, black 20%, var(--SurfaceDark));
  color: var(--TextPrimary);
  padding: 10px 12px;
  outline: none;
}

.BattleFormField input:focus {
  border-color: color-mix(in srgb, var(--SecondaryPurple) 70%, transparent);
}

.BattleSelectInput:focus {
  border-color: color-mix(in srgb, var(--SecondaryPurple) 70%, transparent);
}

.BattleCreateButton {
  border: none;
  border-radius: 10px;
  padding: 11px 12px;
  background: linear-gradient(145deg, var(--SecondaryPurple), var(--PrimaryBlue));
  color: white;
  font-weight: 700;
  cursor: pointer;
}

.BattleCreateButton:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.BattleGhostButton {
  background: color-mix(in srgb, var(--SurfaceLight) 85%, black);
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
}

.BattleCreatedCard {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--Success) 40%, transparent);
  background: color-mix(in srgb, var(--Success) 12%, transparent);
  padding: 12px;
  display: grid;
  gap: 4px;
  max-width: 560px;
}

.BattleCreatedCard small {
  color: color-mix(in srgb, var(--TextPrimary) 88%, var(--Success));
}

.BattleOpenLink {
  width: fit-content;
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--Success) 35%, transparent);
  background: color-mix(in srgb, var(--Success) 16%, transparent);
  padding: 6px 10px;
  font-size: 12px;
  font-weight: 700;
}

.BattleErrorBox {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--Danger) 45%, transparent);
  background: color-mix(in srgb, var(--Danger) 12%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 92%, var(--Danger));
  padding: 12px;
  max-width: 560px;
}

.BattleSuggestWrap {
  display: grid;
  gap: 8px;
}

.BattleSuggestWrap strong {
  font-size: 14px;
}

.BattleSuggestCarousel {
  display: grid;
  grid-template-columns: repeat(3, minmax(220px, 1fr));
  gap: 10px;
}

.BattleSuggestCarouselShell {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 10px;
  align-items: stretch;
}

.BattleSuggestNavButton {
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 52%, transparent);
  background:
    radial-gradient(circle at 80% 12%, color-mix(in srgb, var(--PrimaryYellow) 18%, transparent), transparent 48%),
    color-mix(in srgb, var(--PrimaryBlue) 14%, var(--SurfaceDark));
  color: var(--TextPrimary);
  padding: 10px 12px;
  min-height: 122px;
  min-width: 82px;
  display: grid;
  place-items: center;
  gap: 6px;
  font-weight: 700;
  cursor: pointer;
  box-shadow:
    inset 0 0 0 1px color-mix(in srgb, white 6%, transparent),
    0 10px 22px color-mix(in srgb, black 30%, transparent);
  transition: border-color 140ms ease, transform 140ms ease, opacity 140ms ease, box-shadow 140ms ease;
}

.BattleSuggestNavButton:disabled {
  opacity: 0.45;
  cursor: not-allowed;
  box-shadow: none;
}

.BattleSuggestNavButton:not(:disabled):hover {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 70%, transparent);
  box-shadow:
    inset 0 0 0 1px color-mix(in srgb, var(--PrimaryYellow) 28%, transparent),
    0 12px 24px color-mix(in srgb, black 34%, transparent);
  transform: translateY(-2px);
}

.BattleSuggestNavButton:not(:disabled):active {
  transform: translateY(0);
}

.BattleSuggestNavButtonLeft .BattleSuggestNavIcon,
.BattleSuggestNavButtonRight .BattleSuggestNavIcon {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 36%, transparent);
  background: color-mix(in srgb, black 12%, transparent);
  display: grid;
  place-items: center;
  font-size: 16px;
  line-height: 1;
}

.BattleSuggestNavText {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--TextSecondary);
}

.BattleSuggestCarousel .BattleTinyNote {
  grid-column: 1 / -1;
}

.BattleSuggestCarouselSlideNext {
  animation: BattleSuggestSlideNext 280ms cubic-bezier(0.2, 0.78, 0.2, 1);
}

.BattleSuggestCarouselSlidePrev {
  animation: BattleSuggestSlidePrev 280ms cubic-bezier(0.2, 0.78, 0.2, 1);
}

@keyframes BattleSuggestSlideNext {
  0% {
    opacity: 0.55;
    transform: translateX(28px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes BattleSuggestSlidePrev {
  0% {
    opacity: 0.55;
    transform: translateX(-28px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

.BattleSuggestCard {
  display: grid;
  gap: 5px;
  min-height: 122px;
}

.BattleSuggestCard {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 35%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 10%, transparent);
  color: var(--TextPrimary);
  padding: 10px;
  text-align: left;
  cursor: pointer;
}

.BattleSuggestCardActive {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 65%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 12%, var(--SurfaceDark));
}

.BattleSuggestCardModern {
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 36%, transparent);
  background:
    radial-gradient(circle at 85% 12%, color-mix(in srgb, var(--SecondaryPurple) 18%, transparent), transparent 44%),
    color-mix(in srgb, var(--PrimaryBlue) 10%, var(--SurfaceDark));
}

.BattleSuggestTopRow {
  display: flex;
  align-items: center;
  gap: 10px;
}

.BattleSuggestMeta {
  display: grid;
  gap: 1px;
  min-width: 0;
}

.BattleSuggestTagRow {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.BattleSuggestTagRow span {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 88%, transparent);
  background: color-mix(in srgb, black 14%, transparent);
  padding: 2px 7px;
  font-size: 10px;
  font-weight: 700;
}

.BattleSuggestStatsGrid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 6px;
}

.BattleSuggestStatBlock {
  border-radius: 9px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 90%, transparent);
  background: color-mix(in srgb, black 12%, transparent);
  padding: 6px 8px;
  display: grid;
  gap: 1px;
}

.BattleSuggestStatBlock small {
  color: var(--TextSecondary);
  font-size: 10px;
}

.BattleSuggestStatBlock strong {
  font-size: 13px;
  font-weight: 700;
}

@media (max-width: 1024px) {
  .BattleSuggestCarousel {
    grid-template-columns: repeat(2, minmax(210px, 1fr));
  }
}

@media (max-width: 768px) {
  .BattleSuggestCarouselShell {
    grid-template-columns: 1fr;
  }

  .BattleSuggestCarousel {
    grid-template-columns: 1fr;
  }

  .BattleSuggestNavButton {
    min-height: 46px;
    padding: 10px 14px;
    grid-template-columns: auto auto;
    justify-content: center;
  }

  .BattleSuggestNavText {
    font-size: 11px;
  }
}

.BattleSuggestAvatar {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 24%, transparent);
  display: grid;
  place-items: center;
  overflow: hidden;
}

.BattleSuggestAvatar span {
  color: var(--TextSecondary);
  font-size: 11px;
  font-weight: 800;
}

.BattleSuggestAvatarImg {
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
}

.BattleStepPills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.BattleStepPills span {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  color: var(--TextSecondary);
  padding: 4px 10px;
  font-size: 11px;
  font-weight: 700;
}

.BattleStepPillActive {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 62%, transparent) !important;
  background: color-mix(in srgb, var(--PrimaryYellow) 14%, transparent) !important;
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryYellow)) !important;
}

.BattleSuggestName {
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.BattleSuggestCard small {
  color: var(--TextSecondary);
}

.BattlePickerSection {
  display: grid;
  gap: 8px;
}

.BattlePickerTitle {
  font-size: 12px;
  color: var(--TextSecondary);
  font-weight: 600;
}

.BattlePickerGrid {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
}

.BattlePokemonPick {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  color: var(--TextPrimary);
  padding: 10px;
  display: grid;
  gap: 3px;
  text-align: left;
  cursor: pointer;
}

.BattlePokemonPick small {
  color: var(--TextSecondary);
}

.BattlePlayerPokemonGrid {
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
}

.BattlePokemonPickModern {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 36%, transparent);
  background:
    radial-gradient(circle at 85% 12%, color-mix(in srgb, var(--SecondaryPurple) 18%, transparent), transparent 44%),
    color-mix(in srgb, var(--PrimaryBlue) 10%, var(--SurfaceDark));
  gap: 5px;
}

.BattlePokemonPickTopRow {
  display: flex;
  align-items: center;
  gap: 10px;
}

.BattlePokemonPickMeta {
  display: grid;
  gap: 1px;
  min-width: 0;
}

.BattlePokemonPickMeta strong {
  text-transform: capitalize;
}

.BattlePokemonPickTagRow {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.BattlePokemonPickTagRow span {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 88%, transparent);
  background: color-mix(in srgb, black 14%, transparent);
  padding: 2px 7px;
  font-size: 10px;
  font-weight: 700;
  text-transform: capitalize;
}

.BattlePokemonPickImageWrap {
  width: 56px;
  height: 56px;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 24%, transparent);
  display: grid;
  place-items: center;
  overflow: hidden;
}

.BattlePokemonPickImageWrap span {
  color: var(--TextSecondary);
  font-size: 11px;
  font-weight: 700;
}

.BattlePokemonPickImage {
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
}

.BattlePokemonPickActive {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 68%, transparent);
  background:
    radial-gradient(circle at 85% 12%, color-mix(in srgb, var(--PrimaryYellow) 18%, transparent), transparent 44%),
    color-mix(in srgb, var(--PrimaryBlue) 14%, var(--SurfaceDark));
}

.BattlePreviewWrap {
  display: grid;
  gap: 8px;
}

.BattleRouletteCard {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 35%, transparent);
  background:
    radial-gradient(circle at 86% 12%, color-mix(in srgb, var(--PrimaryYellow) 18%, transparent), transparent 42%),
    color-mix(in srgb, var(--PrimaryYellow) 8%, var(--SurfaceDark));
  padding: 12px;
  display: grid;
  gap: 8px;
  width: 100%;
  min-width: 0;
  max-width: 100%;
}

.BattleRouletteHead {
  display: grid;
  gap: 2px;
}

.BattleRouletteHead small {
  color: var(--TextSecondary);
}

.BattleRouletteWindow {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 45%, transparent);
  background: color-mix(in srgb, black 20%, var(--SurfaceDark));
  padding: 10px;
  display: grid;
  gap: 5px;
  width: 100%;
  min-width: 0;
  max-width: 100%;
}

.BattleRouletteWindowRolling {
  animation: BattleRouletteSpinGlow 0.35s linear infinite;
}

.BattleRouletteLabel {
  width: fit-content;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 42%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 12%, transparent);
  padding: 3px 8px;
  font-size: 10px;
  font-weight: 700;
}

.BattleRouletteWindow strong {
  text-transform: capitalize;
  font-size: 19px;
}

.BattleRouletteCenterMarker {
  position: absolute;
  left: 50%;
  top: 6px;
  transform: translateX(-50%);
  width: 1px;
  height: 11px;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--PrimaryYellow), var(--PrimaryRed));
  box-shadow: 0 0 8px color-mix(in srgb, var(--PrimaryYellow) 65%, transparent);
  z-index: 3;
  pointer-events: none;
}

.BattleRouletteTrackFrame {
  position: relative;
  width: 100%;
  min-width: 0;
  max-width: 100%;
}

.BattleRouletteTrackViewport {
  overflow: hidden;
  padding: 4px 0 8px;
  width: 100%;
  min-width: 0;
  max-width: 100%;
}

.BattleRouletteTrack {
  display: flex;
  gap: 10px;
  padding: 8px calc(50% - 61px);
  will-change: transform;
}

.BattleRouletteTrackRolling {
  transition: transform 5.6s cubic-bezier(0.08, 0.78, 0.08, 1);
}

.BattleRouletteItemCard {
  min-width: 122px;
  width: 122px;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background:
    radial-gradient(circle at 78% 14%, color-mix(in srgb, var(--PrimaryBlue) 18%, transparent), transparent 45%),
    color-mix(in srgb, black 20%, var(--SurfaceDark));
  padding: 8px;
  display: grid;
  gap: 4px;
  text-align: center;
  transition: transform 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
  transform-origin: center center;
}

.BattleRouletteItemCardFocus {
  transform: scale(1.1);
  border-color: color-mix(in srgb, var(--PrimaryBlue) 68%, transparent);
  box-shadow: 0 0 14px color-mix(in srgb, var(--PrimaryBlue) 34%, transparent);
  z-index: 2;
}

.BattleRouletteItemCardWinner {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 72%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 14%, var(--SurfaceDark));
  box-shadow: 0 0 18px color-mix(in srgb, var(--PrimaryYellow) 64%, transparent);
  transform: scale(1.14);
}

.BattleRouletteItemImageWrap {
  width: 100%;
  height: 72px;
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 90%, transparent);
  background:
    radial-gradient(circle at 50% 16%, color-mix(in srgb, var(--PrimaryYellow) 14%, transparent), transparent 60%),
    color-mix(in srgb, black 20%, transparent);
  display: grid;
  place-items: center;
  overflow: hidden;
}

.BattleRouletteItemImageWrap span {
  color: var(--TextSecondary);
  font-size: 10px;
  font-weight: 800;
}

.BattleRouletteItemImage {
  width: 88%;
  height: 88%;
  object-fit: contain;
  filter: drop-shadow(0 2px 4px color-mix(in srgb, black 40%, transparent));
}

.BattleRouletteItemCard small {
  color: var(--TextSecondary);
  text-transform: capitalize;
}

.BattleRouletteFinal {
  color: color-mix(in srgb, var(--TextPrimary) 92%, var(--PrimaryYellow));
  font-weight: 700;
}

.BattleStepActions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

@keyframes BattleRouletteSpinGlow {
  0% {
    box-shadow: 0 0 0 color-mix(in srgb, var(--PrimaryYellow) 0%, transparent);
  }
  50% {
    box-shadow: 0 0 14px color-mix(in srgb, var(--PrimaryYellow) 42%, transparent);
  }
  100% {
    box-shadow: 0 0 0 color-mix(in srgb, var(--PrimaryYellow) 0%, transparent);
  }
}

.BattleOpponentPreviewCard {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 38%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 10%, var(--SurfaceDark));
  padding: 12px;
  display: grid;
  gap: 10px;
}

.BattleOpponentHeader {
  display: grid;
  gap: 2px;
}

.BattleOpponentHeader small {
  color: var(--TextSecondary);
}

.BattleOpponentPokemonList {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
}

.BattleTinyNote {
  border-radius: 10px;
  border: 1px dashed color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
  color: var(--TextSecondary);
  padding: 10px 12px;
}

.BattleAiWrap {
  display: grid;
  gap: 10px;
}

.BattleAiGrid {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  max-width: 760px;
}

.BattleAiCard {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 35%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 10%, var(--SurfaceDark));
  color: var(--TextPrimary);
  padding: 10px;
  display: grid;
  gap: 2px;
  text-align: left;
  cursor: pointer;
}

.BattleAiCard small {
  color: var(--TextSecondary);
}

.BattleAiCardActive {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 70%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 12%, var(--SurfaceDark));
}

.BattleDetailRoot {
  padding: 24px;
  display: grid;
  gap: 16px;
}

.BattleDetailHero {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 35%, var(--SurfaceLight));
  background: color-mix(in srgb, var(--SurfaceDark) 92%, black);
  padding: 16px;
  display: grid;
  gap: 12px;
}

.BattleDetailTag {
  width: fit-content;
  border-radius: 999px;
  padding: 5px 10px;
  font-size: 11px;
  font-weight: 700;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 40%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 17%, transparent);
}

.BattleDetailHero h1 {
  margin: 8px 0 4px;
  font-size: 28px;
}

.BattleDetailHero p {
  margin: 0;
  color: var(--TextSecondary);
}

.BattleDetailCode {
  color: color-mix(in srgb, var(--TextSecondary) 85%, white);
  font-size: 12px;
}

.BattleHeroVersus {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 30%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 10%, transparent);
  padding: 10px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  gap: 8px;
  align-items: center;
}

.BattleHeroFighter {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  padding: 8px;
  display: flex;
  gap: 8px;
  align-items: center;
}

.BattleHeroFighterPhotoWrap {
  width: 52px;
  height: 52px;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 30%, transparent);
  overflow: hidden;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.BattleHeroFighterPhoto {
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
}

.BattleHeroFighterPhotoFallback {
  font-size: 11px;
  font-weight: 800;
  color: var(--TextSecondary);
}

.BattleHeroFighterMeta {
  display: grid;
  gap: 2px;
  min-width: 0;
}

.BattleHeroFighterMeta strong {
  text-transform: capitalize;
}

.BattleHeroFighterMeta small {
  color: var(--TextSecondary);
}

.BattleHeroVsBadge {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 16%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 94%, var(--PrimaryYellow));
  padding: 4px 10px;
  font-size: 11px;
  font-weight: 800;
}

.BattleDetailSection {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 85%, transparent);
  background: color-mix(in srgb, var(--SurfaceDark) 90%, black);
  padding: 16px;
  display: grid;
  gap: 10px;
}

.BattleDetailHeaderRow {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.BattleDetailHeaderRow h2 {
  margin: 0;
  font-size: 19px;
}

.BattleDetailHeaderRow small {
  color: var(--TextSecondary);
}

.BattleArena {
  display: grid;
  gap: 10px;
  grid-template-columns: minmax(220px, 1fr) 140px minmax(220px, 1fr);
  align-items: center;
}

.BattleFighterCard {
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--SecondaryPurple) 36%, transparent);
  background:
    radial-gradient(circle at 15% 12%, color-mix(in srgb, var(--PrimaryBlue) 14%, transparent), transparent 34%),
    color-mix(in srgb, var(--SecondaryPurple) 10%, var(--SurfaceDark));
  padding: 12px;
  display: grid;
  gap: 8px;
  transition: transform 0.2s ease;
}

.BattleFighterCard small {
  color: var(--TextSecondary);
}

.BattleFighterCardCurrentTurn {
  border-color: color-mix(in srgb, var(--PrimaryYellow) 62%, transparent);
  box-shadow: 0 0 0 1px color-mix(in srgb, var(--PrimaryYellow) 30%, transparent);
}

.BattleFighterIdentityRow {
  display: grid;
  grid-template-columns: 110px minmax(0, 1fr);
  gap: 10px;
  align-items: center;
}

.BattleFighterTopRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.BattleFighterSideTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 42%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 16%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryBlue));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.BattleFighterTypeTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 44%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 18%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--SecondaryTeal));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
  text-transform: capitalize;
}

.BattleFighterPhotoWrap {
  width: 110px;
  height: 110px;
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 28%, transparent);
  display: grid;
  place-items: center;
  overflow: hidden;
}

.BattleFighterPhoto {
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
}

.BattleFighterPhotoFallback {
  color: var(--TextSecondary);
  font-weight: 800;
}

.BattleFighterNameBlock {
  display: grid;
  gap: 6px;
}

.BattleFighterNameBlock strong {
  font-size: 18px;
  line-height: 1;
}

.BattleFighterPokemonLine {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.BattleFighterPokemonLine small {
  text-transform: capitalize;
  font-size: 13px;
}

.BattleFighterLevelBadge {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 18%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 94%, var(--PrimaryYellow));
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 700;
}

.BattleHpRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.BattleHpBar {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--SurfaceLight) 80%, transparent);
  overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 95%, transparent);
}

.BattleHpFill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--Danger), var(--Warning), var(--Success));
}

.BattleFighterStatsMini {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 6px;
}

.BattleFighterStatsMini span {
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  padding: 6px 7px;
  font-size: 11px;
  font-weight: 700;
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--PrimaryBlue));
  text-align: center;
}

.BattleFighterCardAttack {
  transform: translateX(6px);
}

.BattleFighterCardHit {
  transform: translateX(-6px);
  filter: brightness(1.2);
}

@media (max-width: 768px) {
  .BattleFighterCardAttack {
    transform: translateX(3px);
  }

  .BattleFighterCardHit {
    transform: translateX(-3px);
  }
}

.BattleImpactFx {
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--PrimaryYellow) 35%, transparent);
  background: color-mix(in srgb, var(--PrimaryYellow) 14%, transparent);
  min-height: 72px;
  display: grid;
  place-items: center;
  text-align: center;
  font-size: 12px;
  font-weight: 800;
  color: color-mix(in srgb, var(--PrimaryYellow) 88%, white);
  opacity: 0.7;
}

.BattleImpactFxActive {
  animation: BattleImpactPulse 0.9s ease;
  opacity: 1;
}

@media (max-width: 980px) {
  .BattleArena {
    grid-template-columns: 1fr;
  }

  .BattleFighterIdentityRow {
    grid-template-columns: 88px minmax(0, 1fr);
  }

  .BattleFighterPhotoWrap {
    width: 88px;
    height: 88px;
  }
}

@keyframes BattleImpactPulse {
  0% {
    transform: scale(0.85);
    opacity: 0.2;
  }
  30% {
    transform: scale(1.1);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.BattleOutcomeShowcase {
  border-radius: 16px;
  padding: 16px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  display: grid;
  gap: 12px;
  box-shadow: 0 14px 28px color-mix(in srgb, black 45%, transparent);
}

.BattleOutcomeShowcaseWin {
  background:
    radial-gradient(circle at 18% 14%, color-mix(in srgb, var(--Success) 28%, transparent), transparent 42%),
    linear-gradient(145deg, color-mix(in srgb, var(--Success) 14%, transparent), color-mix(in srgb, var(--SecondaryTeal) 14%, transparent));
  border-color: color-mix(in srgb, var(--Success) 55%, transparent);
}

.BattleOutcomeShowcaseLose {
  background:
    radial-gradient(circle at 18% 14%, color-mix(in srgb, var(--Danger) 28%, transparent), transparent 42%),
    linear-gradient(145deg, color-mix(in srgb, var(--Danger) 14%, transparent), color-mix(in srgb, var(--Warning) 10%, transparent));
  border-color: color-mix(in srgb, var(--Danger) 55%, transparent);
}

.BattleOutcomeShowcaseDraw {
  background:
    radial-gradient(circle at 18% 14%, color-mix(in srgb, var(--Warning) 24%, transparent), transparent 42%),
    linear-gradient(145deg, color-mix(in srgb, var(--Warning) 14%, transparent), color-mix(in srgb, var(--PrimaryYellow) 10%, transparent));
  border-color: color-mix(in srgb, var(--Warning) 55%, transparent);
}

.BattleOutcomeHeader {
  display: grid;
  gap: 6px;
}

.BattleOutcomeMiniTag {
  width: fit-content;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, white 24%, transparent);
  background: color-mix(in srgb, black 14%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 90%, white);
  font-size: 11px;
  font-weight: 700;
  padding: 4px 9px;
  text-transform: uppercase;
}

.BattleOutcomeTitle {
  font-size: 44px;
  line-height: 0.95;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  text-shadow: 0 0 16px color-mix(in srgb, white 22%, transparent);
}

.BattleOutcomeSubtitle {
  color: color-mix(in srgb, var(--TextPrimary) 90%, white);
  font-size: 13px;
}

.BattleOutcomeFooter {
  display: flex;
  justify-content: flex-end;
}

.BattleOutcomeAction {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, white 28%, transparent);
  background: color-mix(in srgb, black 16%, transparent);
  color: white;
  padding: 8px 12px;
  font-size: 12px;
  font-weight: 800;
}

.BattleActionGrid {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  max-width: 520px;
}

.BattleActionButton {
  border: none;
  border-radius: 10px;
  padding: 10px 12px;
  background: linear-gradient(145deg, var(--SecondaryPurple), var(--PrimaryBlue));
  color: white;
  font-weight: 700;
  cursor: pointer;
}

.BattleTurnsList {
  display: grid;
  gap: 8px;
}

.BattleTurnCard {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  padding: 10px;
  display: grid;
  gap: 3px;
}

.BattleTurnCard small {
  color: var(--TextSecondary);
}

.BattleAutoTimeline {
  display: grid;
  gap: 8px;
  max-height: 240px;
  overflow-y: auto;
  padding-right: 4px;
}

.BattleAutoLogCard {
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--SurfaceLight) 92%, transparent);
  background: color-mix(in srgb, black 18%, var(--SurfaceDark));
  padding: 10px;
  display: grid;
  gap: 4px;
}

.BattleAutoLogCardLatest {
  border-color: color-mix(in srgb, var(--PrimaryBlue) 52%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 14%, transparent);
}

.BattleAutoLogTop {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  align-items: baseline;
}

.BattleAutoActorWrap {
  display: flex;
  gap: 7px;
  align-items: center;
}

.BattleAutoActionWrap {
  display: flex;
  gap: 7px;
  align-items: center;
}

.BattleAutoMiniIcon {
  width: 26px;
  height: 22px;
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--PrimaryBlue) 45%, transparent);
  background: color-mix(in srgb, var(--PrimaryBlue) 16%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 96%, var(--PrimaryBlue));
  font-size: 10px;
  font-weight: 800;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.BattleAutoLogTop small {
  color: color-mix(in srgb, var(--TextPrimary) 92%, var(--PrimaryYellow));
  font-weight: 700;
}

.BattleAutoLogMeta {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.BattleAutoLogMeta small {
  color: var(--TextSecondary);
}

.BattleAutoDataTag {
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--SecondaryTeal) 45%, transparent);
  background: color-mix(in srgb, var(--SecondaryTeal) 14%, transparent);
  color: color-mix(in srgb, var(--TextPrimary) 95%, var(--SecondaryTeal));
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  margin-right: 4px;
}

@media (max-width: 1024px) {
  .DashboardRoot,
  .PokemonRoot,
  .BattlesRoot,
  .BattleDetailRoot {
    padding: 16px;
  }

  .DashboardHero,
  .PokemonHero,
  .BattlesHero,
  .BattleDetailHero,
  .DashboardSection,
  .PokemonSection,
  .BattlesSection,
  .BattleDetailSection {
    padding: 14px;
  }

  .DashboardHeroTitle h1,
  .PokemonHeroTop h1,
  .BattlesHeroTop h1 {
    font-size: 26px;
  }

  .BattleDetailHero h1 {
    font-size: 24px;
  }

  .BattleHeroVersus {
    grid-template-columns: 1fr;
  }

  .BattleHeroVsBadge {
    justify-self: center;
  }

  .ChampionGrid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .BattleFormGrid {
    max-width: none;
  }
}

@media (max-width: 768px) {
  .DashboardRoot,
  .PokemonRoot,
  .BattlesRoot,
  .BattleDetailRoot {
    padding: 12px;
    gap: 12px;
  }

  .DashboardHero,
  .PokemonHero,
  .BattlesHero,
  .BattleDetailHero,
  .DashboardSection,
  .PokemonSection,
  .BattlesSection,
  .BattleDetailSection {
    padding: 12px;
    border-radius: 14px;
  }

  .DashboardHeroTitle h1,
  .PokemonHeroTop h1,
  .BattlesHeroTop h1 {
    font-size: 22px;
  }

  .BattleDetailHero h1 {
    font-size: 20px;
  }

  .DashboardStatsGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .DashboardNavGrid,
  .ChampionGrid,
  .PokemonGrid,
  .StarterGrid,
  .BattleAiGrid,
  .BattlePickerGrid,
  .BattleOpponentPokemonList,
  .BattleOngoingGrid {
    grid-template-columns: 1fr;
  }

  .PageQuickNavLink {
    width: 100%;
    text-align: center;
  }

  .BattleDetailHeaderRow {
    flex-wrap: wrap;
    gap: 6px;
  }

  .BattleFighterIdentityRow {
    grid-template-columns: 72px minmax(0, 1fr);
  }

  .BattleFighterPhotoWrap {
    width: 72px;
    height: 72px;
  }

  .BattleFighterStatsMini {
    grid-template-columns: 1fr;
  }

  .BattleImpactFx {
    min-height: 52px;
  }

  .BattleOutcomeTitle {
    font-size: 34px;
  }

  .DashboardNavTopRow {
    grid-template-columns: 28px minmax(0, 1fr) auto;
  }

  .DashboardNavIcon {
    width: 28px;
    height: 28px;
    font-size: 10px;
  }

  .ChampionImageWrap {
    width: 72px;
    height: 72px;
  }
}

@media (max-width: 480px) {
  .DashboardStatsGrid {
    grid-template-columns: 1fr;
  }

  .DashboardStatCard strong {
    font-size: 18px;
  }

  .DashboardNavTopRow strong,
  .ChampionMeta strong {
    font-size: 16px;
  }

  .BattleOutcomeTitle {
    font-size: 28px;
  }
}
