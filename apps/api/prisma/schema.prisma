generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BattleStatus {
  pending
  active
  finished
  expired
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

enum QuestStatus {
  pending
  completed
  claimed
}

enum UserGender {
  male
  female
}

model User {
  id              String           @id @default(cuid())
  googleSub       String           @unique
  email           String           @unique
  displayName     String
  accountTag      String?          @unique
  avatarUrl       String?
  gender          UserGender       @default(male)
  xp              Int              @default(0)
  level           Int              @default(1)
  coins           Int              @default(0)
  trainingPoints  Int              @default(0)
  pokemonFragments Int             @default(0)
  lootPityCounter Int              @default(0)
  dailyShopPurchases Int           @default(0)
  dailyShopPurchasedAt DateTime?
  mmr             Int              @default(1200)
  totalWins       Int              @default(0)
  totalLosses     Int              @default(0)
  refreshToken    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pokemons        UserPokemon[]
  challengerBattles Battle[]       @relation("BattleChallenger")
  opponentBattles Battle[]         @relation("BattleOpponent")
  quests          UserQuest[]
  lootBoxOpens    LootBoxOpen[]
  sentFriendships Friendship[]     @relation("FriendshipSender")
  receivedFriendships Friendship[] @relation("FriendshipReceiver")
  profileHistory  UserProfileHistory?
  eventClaims     ProgressionEventClaim[]
  lootBoxStates   UserLootBoxState[]
}

model PokemonSpecies {
  id              String         @id @default(cuid())
  pokeApiId       Int            @unique
  name            String         @unique
  typePrimary     String
  typeSecondary   String?
  baseHp          Int
  baseAtk         Int
  baseDef         Int
  baseSpeed       Int
  evolutionTarget String?
  evolutionLevel  Int?
  imageUrl        String?
  dropRarity      String           @default("common")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userPokemons    UserPokemon[]
}

model UserPokemon {
  id                String         @id @default(cuid())
  userId            String
  speciesId         String
  nickname          String?
  level             Int            @default(1)
  xp                Int            @default(0)
  currentHp         Int
  atk               Int
  def               Int
  speed             Int
  lifeUtil          Int            @default(100)
  isLegacy          Boolean        @default(false)
  legacyAt          DateTime?
  fatigue           Int            @default(0)
  fatigueUpdatedAt  DateTime       @default(now())
  trainingCooldownUntil DateTime?
  wins              Int            @default(0)
  losses            Int            @default(0)
  restCooldownUntil DateTime?
  evolveCooldownUntil DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id])
  species           PokemonSpecies @relation(fields: [speciesId], references: [id])
  battleTurns       BattleTurn[]
  challengerBattles Battle[]       @relation("BattleChallengerPokemon")
  opponentBattles   Battle[]       @relation("BattleOpponentPokemon")
  @@index([userId, isLegacy, wins, level])
}

model Battle {
  id                 String        @id @default(cuid())
  challengerId       String
  opponentId         String
  challengerPokemonId String
  opponentPokemonId  String
  status             BattleStatus  @default(pending)
  expiresAt          DateTime
  winnerUserId       String?
  challengerMmrDelta Int           @default(0)
  opponentMmrDelta   Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  challenger         User          @relation("BattleChallenger", fields: [challengerId], references: [id])
  opponent           User          @relation("BattleOpponent", fields: [opponentId], references: [id])
  challengerPokemon  UserPokemon   @relation("BattleChallengerPokemon", fields: [challengerPokemonId], references: [id])
  opponentPokemon    UserPokemon   @relation("BattleOpponentPokemon", fields: [opponentPokemonId], references: [id])
  turns              BattleTurn[]
  @@index([challengerId, status, updatedAt])
  @@index([opponentId, status, updatedAt])
  @@index([winnerUserId, status, createdAt])
}

model BattleTurn {
  id            String      @id @default(cuid())
  battleId      String
  actorUserId   String
  actorPokemonId String
  action        String
  moveName      String?
  moveType      String?
  moveCategory  String?
  movePriority  Int?
  moveDamageMultiplier Float?
  moveControlChance Float?
  nextActorUserId String?
  damage        Int
  challengerHp  Int
  opponentHp    Int
  idempotencyKey String
  createdAt     DateTime    @default(now())
  battle        Battle       @relation(fields: [battleId], references: [id])
  actorPokemon  UserPokemon  @relation(fields: [actorPokemonId], references: [id])
  @@unique([battleId, idempotencyKey])
  @@index([battleId, createdAt])
}

model UserQuest {
  id            String     @id @default(cuid())
  userId        String
  questCode     String
  progress      Int        @default(0)
  target        Int
  rewardXp      Int
  rewardCoins   Int
  status        QuestStatus @default(pending)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id])
  @@unique([userId, questCode])
}

model LootBoxOpen {
  id            String     @id @default(cuid())
  userId        String
  boxType       String     @default("standard")
  requestId     String?
  rewardRarity  String?
  rewardType    String
  rewardValue   String
  fragmentGain  Int        @default(0)
  wasDuplicate  Boolean    @default(false)
  pityBefore    Int        @default(0)
  pityAfter     Int        @default(0)
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id])
  @@unique([userId, requestId])
  @@index([userId, createdAt])
}

model UserLootBoxState {
  id                  String   @id @default(cuid())
  userId              String
  boxType             String
  pityCounter         Int      @default(0)
  dailyShopPurchases  Int      @default(0)
  dailyShopPurchasedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id])
  @@unique([userId, boxType])
  @@index([userId])
}

model ProgressionEventClaim {
  id          String   @id @default(cuid())
  userId      String
  eventCode   String
  dayKey      String
  rewardType  String
  rewardValue String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  @@unique([userId, eventCode, dayKey])
}

model Friendship {
  id            String            @id @default(cuid())
  senderId      String
  receiverId    String
  status        FriendshipStatus  @default(pending)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sender        User              @relation("FriendshipSender", fields: [senderId], references: [id])
  receiver      User              @relation("FriendshipReceiver", fields: [receiverId], references: [id])
  @@unique([senderId, receiverId])
  @@index([receiverId, status, updatedAt])
  @@index([senderId, status, updatedAt])
}

model UserProfileHistory {
  id            String    @id @default(cuid())
  userId        String    @unique
  battleCount   Int       @default(0)
  bestStreak    Int       @default(0)
  totalDamage   Int       @default(0)
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])
}

model CatalogSyncRun {
  id            String    @id @default(cuid())
  triggeredById String?
  status        String
  limitUsed     Int
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  details       String?
}

model AuditLog {
  id            String    @id @default(cuid())
  actorUserId   String?
  action        String
  entityName    String
  entityId      String?
  payload       String?
  createdAt     DateTime  @default(now())
  @@index([actorUserId, action, entityName, createdAt])
}
