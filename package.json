{
  "name": "battleLeagueMonorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @battleleague/api",
    "dev:web": "npm run dev --workspace @battleleague/web",
    "dev:api": "npm run dev --workspace @battleleague/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
